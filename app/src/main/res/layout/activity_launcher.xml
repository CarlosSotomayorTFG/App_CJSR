<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="56dp"
            android:paddingBottom="16dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:id="@+id/tvSubjectLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_platform"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Section label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PLATAFORMAS"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.14"
                android:layout_marginBottom="12dp"/>

            <!-- Grid row 1: YouTube + Instagram -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- YouTube -->
                <LinearLayout
                    android:id="@+id/cardYoutube"
                    android:layout_width="0dp"
                    android:layout_height="148dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="26dp"
                        android:src="@drawable/ic_youtube"
                        android:contentDescription="YouTube"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:text="YouTube"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Instagram -->
                <LinearLayout
                    android:id="@+id/cardInstagram"
                    android:layout_width="0dp"
                    android:layout_height="148dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="26dp"
                        android:src="@drawable/ic_instagram"
                        android:contentDescription="Instagram"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:text="Instagram"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Grid row 2: Reddit + TikTok -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Reddit -->
                <LinearLayout
                    android:id="@+id/cardReddit"
                    android:layout_width="0dp"
                    android:layout_height="148dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="26dp"
                        android:src="@drawable/ic_reddit"
                        android:contentDescription="Reddit"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:text="Reddit"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- TikTok -->
                <LinearLayout
                    android:id="@+id/cardTiktok"
                    android:layout_width="0dp"
                    android:layout_height="148dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="26dp"
                        android:src="@drawable/ic_tiktok"
                        android:contentDescription="TikTok"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:text="TikTok"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Section label: Referencia -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="REFERENCIA"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.14"
                android:layout_marginBottom="12dp"/>

            <!-- Lectura / Baseline (horizontal, full width) -->
            <LinearLayout
                android:id="@+id/cardReading"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_reading"
                        android:tint="@color/colorReading"
                        android:contentDescription="Lectura"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lectura"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sesión de referencia"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BASELINE"
                        android:textColor="@color/colorAccent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:background="@drawable/chip_accent"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Settings button -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#1AFFFFFF"/>

            <Button
                android:id="@+id/btnSettings"
                style="?attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="4dp"
                android:text="Ajustes"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14sp"
                android:drawableStart="@drawable/ic_settings"
                android:drawablePadding="10dp"
                android:drawableTint="@color/colorTextSecondary"
                android:gravity="center"
                android:contentDescription="Configuración"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
