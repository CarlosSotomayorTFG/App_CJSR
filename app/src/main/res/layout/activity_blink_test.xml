<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:paddingTop="48dp"
    android:paddingHorizontal="20dp"
    android:paddingBottom="20dp">

    <!-- Header con botón volver -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Volver"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Test Parpadeo"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Cara detectada -->
    <TextView
        android:id="@+id/tvFaceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="◉  Sin cara detectada"
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_marginBottom="20dp"/>

    <!-- EAR actual -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EAR"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tvEar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#58D68D"
        android:textSize="64sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvEyeState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="umbral: 0.15"
        android:textColor="#555555"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Parpadeos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvBlinkCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="parpadeos total"
                android:textColor="#888888"
                android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvBpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="parp/min (60 s)"
                android:textColor="#888888"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnStartBlink"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Iniciar cámara"
            android:backgroundTint="#1E88E5"/>

        <Button
            android:id="@+id/btnStopBlink"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Detener"
            android:backgroundTint="#555555"/>
    </LinearLayout>

    <!-- Log -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Log"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1A1A1A">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"/>
    </ScrollView>

</LinearLayout>
